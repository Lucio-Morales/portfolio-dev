---
import { Image } from "astro:assets";
import profileImage from "../assets/profile-img.webp";
---

<section class="hero">
    <div class="hero-content">
        <div class="text-container">
            <span class="pre-title">Portfolio Personal</span>
            <h1>
                Lucio <br />
                <span class="accent">Morales</span>
            </h1>
            <p class="subtitle">Sitios web para profesionales y negocios.</p>
            <div class="divider"></div>
        </div>

        <div class="image-wrapper">
            <Image
                src={profileImage}
                alt="Foto de perfil de Lucio Morales"
                width={400}
                height={400}
                loading="eager"
                class="foto-perfil"
            />
        </div>
    </div>
</section>

<style>
    .hero {
        background-color: #161616;
        color: white;
        padding-top: 8rem;
        padding-bottom: 0;
        display: flex;
        justify-content: center;
        overflow: visible;
    }

    .hero-content {
        /* border: 1px solid white; */
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        max-width: 1100px;
        gap: 2rem;
        padding: 0 2rem;
    }

    .text-container {
        flex: 1.2;
        z-index: 2;
    }

    /* Estilo para el pequeño texto superior (Lato) */
    .pre-title {
        font-family: "Lato", sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        font-size: 0.75rem;
        color: #888;
        display: block;
        margin-bottom: 1rem;
    }

    /* Estilo para el nombre (Playfair Display) */
    h1 {
        font-family: "Playfair Display", serif;
        font-size: clamp(3.5rem, 8vw, 7rem); /* Grande y responsivo */
        line-height: 0.9;
        font-weight: 600;
        margin: 0;
        font-style: italic;
    }

    .accent {
        font-family: "Playfair Display", serif;
        font-style: italic;
        color: #c3c3c3;
        font-weight: 400;
    }

    /* Estilo para el cargo (Lato) */
    .subtitle {
        font-family: "Lato", sans-serif;
        font-size: 1.5rem;
        font-weight: 300;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-top: 1.5rem;
        color: #ccc;
    }

    .divider {
        width: 100px;
        height: 1px;
        background-color: #c3c3c3;
        margin-top: 2rem;
    }

    .image-wrapper {
        flex: 0.8;
        display: flex;
        justify-content: flex-end;
        position: relative;
        z-index: 10;
        margin-bottom: -120px; /* Aumentado un poco para que pise más la sig. sección */
    }

    .foto-perfil {
        width: 100%;
        max-width: 380px;
        height: auto;
        filter: grayscale(100%); /* para enfatizar el look monocromo */
        transition: filter 0.5s ease;
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.7);
    }

    .foto-perfil:hover {
        filter: grayscale(0%);
    }

    @media (max-width: 768px) {
        .hero {
            padding-top: 4rem;
        }
        .hero-content {
            flex-direction: column;
            text-align: center;
        }
        .text-container {
            order: 2;
            margin-top: 3rem;
        }
        .image-wrapper {
            order: 1;
            justify-content: center;
            margin-bottom: -60px;
            width: 100%;
        }
        .divider {
            margin: 2rem auto 2rem;
        }
        h1 {
            font-size: 4rem;
        }
    }
</style>
