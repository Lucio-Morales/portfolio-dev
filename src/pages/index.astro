---
import { Image } from "astro:assets";
import projectImage from "../assets/project.webp";
import Hero from "../components/Hero.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<main>
		<Hero />

		<section class="proyectos">
			<div class="content">
				<div class="head-section">
					<h2>Algunos de mis trabajos</h2>
				</div>
				<div class="proyectos-grid">
					<article class="proyecto-item" style="--numero: '01';">
						<div class="proyecto-info">
							<h3>Nombre del Proyecto 1</h3>
							<p>
								Una breve descripción detallando la solución
								técnica y el impacto del proyecto.
							</p>
							<a href="#" class="link-proyecto">Ver detalles →</a>
						</div>
						<div class="proyecto-visual">
							<Image
								src={projectImage}
								alt="Vista previa del proyecto"
							/>
						</div>
					</article>

					<article class="proyecto-item" style="--numero: '02';">
						<div class="proyecto-info">
							<h3>Nombre del Proyecto 2</h3>
							<p>
								Una breve descripción detallando la solución
								técnica y el impacto del proyecto.
							</p>
							<a href="#" class="link-proyecto">Ver detalles →</a>
						</div>
						<div class="proyecto-visual">
							<Image
								src={projectImage}
								alt="Vista previa del proyecto"
							/>
						</div>
					</article>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.proyectos {
		padding-top: 200px;
		min-height: 500px;
		position: relative;
		z-index: 1;
	}

	.content {
		max-width: 1200px;
		margin: 0 auto;
	}

	h2 {
		font-size: 2.6rem;
		margin-bottom: 2rem;
		font-style: italic;
		color: #343434;
	}

	.head-section {
		padding: 20px 0 0 40px;
		border-bottom: 2px solid #b5b5b5;
	}

	.proyectos-grid {
		display: flex;
		flex-direction: column;
		gap: 80px; /* Espacio entre proyectos */
		padding: 60px 40px;
	}

	.proyecto-item {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: 50px;
	}

	.proyecto-info h3 {
		font-size: 1.8rem;
		color: #343434;
		margin-bottom: 1rem;
		font-weight: 600;
	}

	.proyecto-info p {
		font-size: 1.1rem;
		line-height: 1.6;
		color: #555;
		margin-bottom: 1.5rem;
	}

	.link-proyecto {
		text-decoration: none;
		color: #343434;
		font-weight: bold;
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		border-bottom: 1px solid transparent;
		transition: border-color 0.3s ease;
	}

	.link-proyecto:hover {
		border-bottom: 1px solid #343434;
	}

	.proyecto-visual img {
		width: 100%;
		height: auto;
		border-radius: 4px; /* Un toque sutil */
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05); /* Sombra suave para elegancia */
		transition: transform 0.4s ease;
	}

	.proyecto-visual img:hover {
		transform: scale(1.02);
	}

	.proyecto-item {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: 50px;
		position: relative; /* Necesario para posicionar el número detrás */
		padding: 40px 0;
	}

	/* El número decorativo de fondo */
	.proyecto-item::before {
		content: var(--numero); /* Toma el valor definido en el HTML */
		position: absolute;
		top: -20px;
		left: -20px;

		/* Tipografía y Estética */
		font-size: 12rem; /* Tamaño masivo para impacto visual */
		font-weight: 800;
		font-style: normal; /* Contraste con el itálico del H2 */
		color: rgba(0, 0, 0, 0.09); /* Transparencia muy sutil */

		line-height: 1;
		z-index: -1; /* Lo envía detrás de todo el contenido */
		pointer-events: none; /* Evita que interfiera con clicks */
		font-family: serif; /* O la fuente que prefieras para contraste */
	}

	@media (max-width: 768px) {
		.proyecto-item {
			grid-template-columns: 1fr;
			gap: 30px;
		}

		.proyecto-item::before {
			font-size: 8rem;
			top: -10px;
			left: 10px;
		}

		.proyecto-visual {
			order: -1;
		}
	}
</style>
