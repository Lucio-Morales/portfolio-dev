---
import Hero from "../components/Hero.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<main>
		<Hero />

		<section class="proyectos">
			<div class="content">
				<div class="head-section">
					<h2>Algunos de mis trabajos</h2>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.proyectos {
		padding-top: 200px;
		min-height: 500px;
		position: relative;
		z-index: 1;
	}

	.content {
		max-width: 1100px;
		margin: 0 auto;
	}

	h2 {
		font-size: 2.6rem;
		margin-bottom: 2rem;
		font-style: italic;
		color: #343434;
	}

	.head-section {
		padding: 20px 0 0 40px;
		border-bottom: 2px solid #b5b5b5;
		/* background-color: #ffa4a4; */
	}
</style>
