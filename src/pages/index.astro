---
import Hero from "../components/Hero.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mi Portfolio">
	<main>
		<Hero />

		<section class="proyectos">
			<div class="content">
				<h2>Mis Proyectos</h2>
				<p>Aquí puedes ver mis trabajos más recientes.</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	.proyectos {
		padding-top: 200px;
		min-height: 500px;
		position: relative;
		z-index: 1;
	}

	.content {
		max-width: 1100px;
		margin: 0 auto;
	}

	h2 {
		font-size: 2.5rem;
		margin-bottom: 2rem;
	}
</style>
