---
interface Props {
	title?: string;
}

const { title = "Mi Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
			rel="stylesheet"
		/>

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--font-titles: "Playfair Display", serif;
		--font-body: "Lato", sans-serif;
		--max-width: 1200px;
		--container-padding: 2rem;
		--bg-color: #eaf1ff;
		--text-color: #141414;
		--accent-color: #4281e0;
	}
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: var(--font-body);
		font-weight: 400; /* Peso normal de lectura */
		line-height: 1.6;
		color: var(--text-color);
		scroll-behavior: smooth;
	}
	body {
		min-height: 100vh;
	}
	section {
		padding: 4rem var(--container-padding);
		/* max-width: var(--max-width); */
		margin: 0 auto; /* Centra el contenido */
	}

	h1,
	h2,
	h3,
	h4,
	.title-font {
		font-family: var(--font-titles);
		font-weight: 700;
		line-height: 1.2;
		text-wrap: balance;
	}
</style>
